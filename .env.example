# ============================================================
# Admin panel — environment variables
# ============================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored by Next.js; never commit secrets.

# ---- Database (Neon / Vercel Postgres) ---------------------
# Get this from https://console.neon.tech after creating a project,
# or from Vercel Dashboard → Storage → Postgres → .env.local tab.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ---- Auth.js (NextAuth v5) ---------------------------------
# A random 32-byte secret used to sign JWT session cookies.
# Generate once with:  openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"

# Required by Auth.js v5 when running behind a reverse proxy (Vercel is one).
# For local dev this can be the dev URL; in prod set to your real URL.
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ---- Seed user (used only by scripts/seed-admin-user.mjs) --
SEED_USERNAME="capitalism"
SEED_PASSWORD="666999"

# ---- Content writes (GitHub API) ---------------------------
# In DEV (no GITHUB_TOKEN): the content store writes directly to the local
# filesystem — convenient for testing, but not usable on Vercel serverless
# (read-only FS outside /tmp).
#
# In PROD: set these so the admin commits blog edits to GitHub, which
# triggers Vercel to rebuild the public site with the new content.
#
# Create a fine-grained personal access token at:
#   https://github.com/settings/tokens?type=beta
# Scope: only the Bankai-Agency/sosmovingDIMA repo, Contents = Read+Write.
GITHUB_TOKEN=""
GITHUB_REPO="Bankai-Agency/sosmovingDIMA"
GITHUB_BRANCH="main"

# ---- Scheduled-publish cron --------------------------------
# Shared secret between Vercel Cron and /api/cron/publish-scheduled.
# Set the same value in Vercel Dashboard → Settings → Environment Variables
# and here. Leave blank in local dev to skip the check.
# Generate: openssl rand -hex 32
CRON_SECRET=""
